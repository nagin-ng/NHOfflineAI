<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="6dp"
    android:gravity="start"
    android:orientation="vertical">

    <!-- Dynamic content: text segments and code blocks get added here at bind-time -->
    <LinearLayout
        android:id="@+id/bubble_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="30dp"
        android:background="@drawable/bg_assistant_message"
        android:orientation="vertical"
        android:padding="12dp" />

    <ImageButton
        android:id="@+id/copy_btn"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginTop="2dp"
        android:layout_marginStart="4dp"
        android:background="@android:color/transparent"
        android:src="@drawable/outline_copy_24"
        app:tint="@color/nh_text_muted"
        android:contentDescription="Copy response"
        android:padding="5dp"
        android:visibility="gone" />
</LinearLayout>
