<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:orientation="vertical"
    android:background="@drawable/bg_code_block">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_code_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp">

        <TextView
            android:id="@+id/code_lang"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="code"
            android:textColor="@color/nh_text_muted"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <ImageButton
            android:id="@+id/code_copy_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@android:color/transparent"
            android:src="@drawable/outline_copy_24"
            app:tint="@color/nh_gold_soft"
            android:contentDescription="Copy code"
            android:padding="4dp" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <TextView
            android:id="@+id/code_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:padding="12dp"
            android:textColor="#D8E8D0"
            android:textSize="12.5sp"
            android:fontFamily="monospace" />
    </HorizontalScrollView>
</LinearLayout>
